# PostgreSQL connection string (Neon, Supabase, Railway, or local Postgres all work)
DATABASE_URL="postgresql://user:password@localhost:5432/xcellent"

# Random 32+ character string used to sign session cookies. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-string"

# Resend (https://resend.com) — used to send verification emails
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="Xcellent <onboarding@yourdomain.com>"

# Paystack (https://dashboard.paystack.com/#/settings/developer) — use test keys while building
PAYSTACK_SECRET_KEY="sk_test_your_key_here"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_your_key_here"

# Full URL of your app, no trailing slash. Used for email links and Paystack callback.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
